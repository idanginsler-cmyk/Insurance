# Optional environment overrides for the fraud-detection POC.

# SQLite database path (default: ./data/store/fraud_detection.db)
# FD_DB_PATH=/var/lib/fraud-detection/store.db

# Preferred OCR engine: "tesseract" | "easyocr" | "auto"
# FD_OCR_ENGINE=auto

# OCR languages (Tesseract format; EasyOCR uses 'he,en' internally)
# FD_OCR_LANG=heb+eng

# Enable CLIP embeddings (requires sentence-transformers + torch ~2GB)
# FD_USE_EMBEDDINGS=false
